# ========================================
# yunxiao-full分支 - 云效全量推送
# ========================================
# 
# 此分支用于云效推送，包含：
# - 项目代码
# - 小说内容（章节大纲、设定、总大纲等）
# - 技能目录
# - 小说提取器（.novel-extractor）
# ========================================

# 案例库太大（17GB），不推送
.case-library/

# ========================================
# 运行时状态 - 本地私有（仍排除）
# ========================================

.state/
.opencode/
.serena/
.agents/
.project_memory/

# Qdrant本地数据
.vectorstore/qdrant/

# 日志和缓存
logs/
.cache/
*.log
*.cache

# ========================================
# 配置文件 - 含本地路径（仍排除）
# ========================================

config.json
config.local.json
system_config.json
.env
*.env

# JSON数据文件 - 云效推送时保留
# 注意：yunxiao-full分支推送小说数据JSON
# 但仍排除config等含本地路径的配置

# ========================================
# IDE 和编辑器（仍排除）
# ========================================

.vscode/
.idea/
*.swp
*.swo
*~

# ========================================
# OS 文件（仍排除）
# ========================================

.DS_Store
Thumbs.db
Desktop.ini

# ========================================
# Python（仍排除）
# ========================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ========================================
# 临时文件（仍排除）
# ========================================

*.tmp
*.bak
*.backup
*.old
*.orig

# 根目录临时测试文件
/test_*.py
/test_*.txt
/temp_*.txt
/verify_*.py
/fix_*.py

# 测试数据库
.test_chroma/
.test_qdrant/

# ========================================
# 测试覆盖率（仍排除）
# ========================================

htmlcov/
.tox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ========================================
# 向量库缓存（仍排除）
# ========================================

.vectorstore/__pycache__/
.vectorstore/*/__pycache__/
.vectorstore/*/segments/
.vectorstore/*/temp_segments/
*.pickle
*.index

# ========================================
# 数据库文件（仍排除）
# ========================================

*.sqlite
*.sqlite3

# ========================================
# 归档文件（仍排除）
# ========================================

archived/